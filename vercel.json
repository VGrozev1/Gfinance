{
  "installCommand": "pip install --break-system-packages -r requirements.txt",
  "buildCommand": "mkdir -p public && cp -r frontend/* public/",
  "trailingSlash": true,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api" },
    { "source": "/health", "destination": "/api" },
    { "source": "/confirm", "destination": "/api?x-path=/api/book/confirm" },
    { "source": "/decline", "destination": "/api?x-path=/api/book/decline" }
  ]
}

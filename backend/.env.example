# Gfinance Backend - Environment Configuration
# Copy to .env and fill in. Never commit .env to Git.
# See backend/CONFIG.md for full setup instructions.

# === REQUIRED ===

# Supabase (database & auth)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
# JWT Secret: Supabase Dashboard → Settings → API → JWT Secret (for /api/auth/me)

# Google Calendar (booking flow)
GOOGLE_SERVICE_ACCOUNT_FILE=credentials/google-calendar.json
GOOGLE_CALENDAR_ID=

# Admin emails (comma-separated). Users with these emails get role=admin.
ADMIN_EMAILS=vikigrozev@gmail.com,bibigrozeva@gmail.com

# API base URL used in email links (Confirm/Decline). Set to your public URL in production.
API_BASE_URL=http://localhost:8000

# === OPTIONAL ===

# Email (SMTP). If empty, confirmation emails are logged to console instead of sent.
# Use vikigrozev@gmail.com for testing so emails appear "from" the site.
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=

# Database URL (optional; used for direct Postgres access. Supabase client uses SUPABASE_URL.)
# DATABASE_URL=postgresql://postgres:PASSWORD@db.xxx.supabase.co:5432/postgres
